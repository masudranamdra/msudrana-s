# Auto detect text files and normalize line endings to LF
* text=auto

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.zip binary
*.exe binary
*.dll binary

# Node modules (preserve as-is)
node_modules/** -text

# Scripts should have LF endings
*.sh text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
